<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{% if title %}{{ title }} · {{ site.title }}{% else %}{{ site.title }} · {{ site.institution }}{% endif %}</title>
    <meta name="description" content="{{ description or site.description }}" />

    <meta property="og:title" content="{% if title %}{{ title }} · {{ site.title }}{% else %}{{ site.title }}{% endif %}" />
    <meta property="og:description" content="{{ description or site.description }}" />
    <meta property="og:type" content="website" />
    <meta name="theme-color" content="#002a4e" />

    {# Flag JS availability before first paint so reveal-on-scroll styles
       only ever hide content when the script that reveals it will run. #}
    <script>document.documentElement.className += " js";</script>

    <link rel="icon" href="{{ site.logo }}" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&display=swap"
      rel="stylesheet"
    />
    <link rel="stylesheet" href="/assets/css/styles.css" />
  </head>
  <body>
    <a class="skip-link" href="#main">Skip to main content</a>
    {% include "partials/header.njk" %}
    <main id="main">{{ content | safe }}</main>
    {% include "partials/footer.njk" %}
    <script src="/assets/js/main.js" defer></script>
  </body>
</html>
